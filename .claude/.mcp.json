{
  "mcpServers": {
    "github-remote": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search@0.6.2"
      ],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "tradingview-mcp": {
      "type": "sse",
      "url": "http://localhost:8080/sse",
      "command": "docker",
      "args": ["run", "--rm", "-p", "8080:8000", "atilaahmet/tradingview-mcp:latest"]
    },
    "tradingview-screener": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "tradingview-mcp-server@0.6.1"]
    },
    "crypto-rss": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "git+https://github.com/kukapay/crypto-rss-mcp.git@2cc6a514bfe1c028ddf55193dcfa1073ae2ab3fe", "crypto-rss-mcp"]
    }
  }
}